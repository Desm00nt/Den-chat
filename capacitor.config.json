{
  "appId": "com.denchat.app",
  "appName": "Den Chat",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "LocalNotifications": {
      "smallIcon": "ic_stat_icon",
      "iconColor": "#6366f1"
    }
  },
  "android": {
    "allowMixedContent": true,
    "captureInput": true,
    "webContentsDebuggingEnabled": true,
    "initialFocus": true,
    "backgroundColor": "#0f172a",
    "minWebViewVersion": 60
  }
}
